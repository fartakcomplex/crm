generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CMS Core Models
// =============================================================================

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @default("")
  excerpt     String   @default("")
  status      String   @default("draft")
  featured    Boolean  @default(false)
  authorId    String
  categoryId  String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        PostTag[]
  comments    Comment[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("editor")
  avatar    String   @default("")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
  activities ActivityLog[]
}

model Customer {
  id          String         @id @default(cuid())
  name        String
  email       String         @unique
  phone       String         @default("")
  company     String         @default("")
  status      String         @default("active")
  value       Float          @default(0)
  source      String         @default("direct")
  tags        String         @default("")
  address     String         @default("")
  city        String         @default("")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orders      Order[]
  invoices    Invoice[]
  crmActivities CrmActivity[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("planning")
  progress    Int      @default(0)
  priority    String   @default("medium")
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("member")
  department String  @default("")
  avatar    String   @default("")
  status    String   @default("active")
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  author    String   @default("")
  email     String   @default("")
  status    String   @default("pending")
  postId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id])
}

model Media {
  id        String   @id @default(cuid())
  name      String
  filename  String
  url       String
  type      String   @default("image")
  size      Int      @default(0)
  alt       String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String   @default("#6366f1")
  postCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Tag {
  id   String   @id @default(cuid())
  name String   @unique
  slug String   @unique()
  posts PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post  @relation(fields: [postId], references: [id])
  tag    Tag   @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String   @default("")
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
  group String @default("general")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("todo")
  priority    String   @default("medium")
  assigneeId  String?
  dueDate     DateTime?
  tags        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuickNote {
  id        String   @id @default(cuid())
  content   String
  color     String   @default("yellow")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WPSyncConfig {
  id          String         @id @default(cuid())
  siteUrl     String
  apiKey      String
  username    String
  syncFreq    String         @default("manual")
  lastSync    DateTime?
  active      Boolean        @default(true)
  syncedPosts WPSyncedPost[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model WPSyncedPost {
  id           String       @id @default(cuid())
  wpPostId     Int
  localPostId  String
  syncStatus   String       @default("synced")
  syncedAt     DateTime     @default(now())
  wpConfigId   String
  wpConfig     WPSyncConfig @relation(fields: [wpConfigId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean  @default(false)
  color       String   @default("violet")
  location    String   @default("")
  type        String   @default("event")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================================================
// Business Models — Cross-Module Integration
// =============================================================================

// Product: Links Store ↔ Inventory ↔ Accounting (via invoice items)
model Product {
  id            String            @id @default(cuid())
  name          String
  sku           String            @unique
  description   String            @default("")
  price         Float             @default(0)
  salePrice     Float?
  cost          Float             @default(0)
  status        String            @default("active")
  featured      Boolean           @default(false)
  images        String            @default("[]")
  productCategoryId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  productCategory ProductCategory? @relation(fields: [productCategoryId], references: [id])
  orderItems    OrderItem[]
  invoiceItems  InvoiceItem[]
  inventory     InventoryItem?
}

model ProductCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  description String  @default("")
  color     String    @default("#6366f1")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

// Order: Links Store ↔ Customer ↔ Accounting (via invoices)
model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @unique
  customerId      String
  status          String    @default("pending")
  subtotal        Float     @default(0)
  discount        Float     @default(0)
  tax             Float     @default(0)
  shippingCost    Float     @default(0)
  total           Float     @default(0)
  shippingAddress String    @default("")
  notes           String    @default("")
  couponId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customer        Customer  @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  coupon          Coupon?   @relation(fields: [couponId], references: [id])
  invoices        Invoice[]
  outboundRecords OutboundRecord[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  totalPrice Float
  createdAt DateTime @default(now())
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   @default("percent")
  value       Float    @default(0)
  minPurchase Float    @default(0)
  maxUses     Int      @default(0)
  usedCount   Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

// Inventory: Links to Product + tracks stock movements
model InventoryItem {
  id            String            @id @default(cuid())
  productId     String            @unique
  stock         Int               @default(0)
  minStock      Int               @default(5)
  warehouse     String            @default("main")
  location      String            @default("")
  lastRestocked DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  product       Product           @relation(fields: [productId], references: [id])
  inboundRecords  InboundRecord[]
  outboundRecords OutboundRecord[]
}

model InboundRecord {
  id              String        @id @default(cuid())
  inventoryItemId String
  quantity        Int
  reference       String        @default("")
  supplier        String        @default("")
  unitCost        Float         @default(0)
  notes           String        @default("")
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

model OutboundRecord {
  id              String        @id @default(cuid())
  inventoryItemId String
  quantity        Int
  orderId         String?
  reference       String        @default("")
  notes           String        @default("")
  createdAt       DateTime      @default(now())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])
}

// Invoice: Links Accounting ↔ Customer ↔ Store (via order) ↔ Products
model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique
  customerId    String
  orderId       String?
  status        String         @default("draft")
  subtotal      Float          @default(0)
  tax           Float          @default(0)
  discount      Float          @default(0)
  total         Float          @default(0)
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String         @default("")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customer      Customer       @relation(fields: [customerId], references: [id])
  order         Order?         @relation(fields: [orderId], references: [id])
  items         InvoiceItem[]
  transactions  Transaction[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String?
  description String  @default("")
  quantity    Int
  unitPrice   Float
  total       Float
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
}

// Transaction: Links Accounting ↔ Finance ↔ Bank
model Transaction {
  id            String       @id @default(cuid())
  type          String       @default("expense")
  amount        Float        @default(0)
  description   String       @default("")
  category      String       @default("")
  invoiceId     String?
  bankAccountId String?
  reference     String       @default("")
  createdAt     DateTime     @default(now())
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
}

model BankAccount {
  id            String        @id @default(cuid())
  name          String
  accountNumber String        @default("")
  balance       Float         @default(0)
  currency      String        @default("IRR")
  type          String        @default("checking")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
}

// CRM Activity: Links CRM ↔ Customer
model CrmActivity {
  id          String   @id @default(cuid())
  customerId  String
  type        String   @default("note")
  title       String   @default("")
  description String   @default("")
  outcome     String   @default("")
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id])
}

// Budget: Used by Finance module
model BudgetItem {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("")
  allocated   Float    @default(0)
  spent       Float    @default(0)
  period      String   @default("monthly")
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Backup: Tracks database backup records
model BackupRecord {
  id          String   @id @default(cuid())
  filename    String
  filePath    String
  sizeBytes   Int      @default(0)
  type        String   @default("daily")   // daily | weekly | manual
  status      String   @default("completed") // completed | failed | restoring
  note        String   @default("")
  createdAt   DateTime @default(now())
}
